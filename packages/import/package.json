{
  "name": "@skillctl/import",
  "version": "0.2.0",
  "description": "Import/migrate skills from npx skills and Python skillctl",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "node --test ./dist/test/*.test.js 2>&1 || echo 'run after build'",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@skillctl/core": "workspace:*",
    "@skillctl/lockfile": "workspace:*",
    "@skillctl/manifest": "workspace:*",
    "@skillctl/registry": "workspace:*",
    "@skillctl/adapters": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.6.3"
  },
  "engines": { "node": ">=20.12" }
}