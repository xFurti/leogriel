{
  "name": "@leogriel/registry",
  "version": "1.0.0-beta.3",
  "description": "Immutable GitHub, npm, local, and skills.sh source resolution for Leogriel",
  "license": "MIT",
  "author": "xFurti & Gabry848",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/test"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "lint": "tsc --noEmit",
    "test": "node --test ./dist/test/*.test.js",
    "prepack": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@leogriel/core": "workspace:*",
    "@leogriel/lockfile": "workspace:*",
    "@leogriel/manifest": "workspace:*",
    "@leogriel/project-state": "workspace:*",
    "js-yaml": "^4.1.0",
    "semver": "^7.6.3",
    "tar": "^7.5.20"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/js-yaml": "^4.0.9",
    "@types/semver": "^7.5.8",
    "rimraf": "^5.0.7",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.13"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xFurti/leogriel.git",
    "directory": "packages/registry"
  },
  "keywords": [
    "registry",
    "sources",
    "github",
    "npm",
    "resolution",
    "agent-skills"
  ]
}
